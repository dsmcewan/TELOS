{
  "component": "iliad",
  "note": "Authority-anchored comprehension queries for the Iliad role module. These encode the likely hallucinations about the lifecycle: that an Iliad orchestrator runs things, that enrollment absorbs a product into the spine, that retrospectives are optional paperwork, that the pre-review verifies provider catalogs.",
  "governing_authority": {
    "plan": "docs/runs/clotho-daedalus-delta14/matured-plan-v15.md",
    "plan_ref": "sha256:05a48700f92938e5fe1cf42199434ec163c86c9bda4f637d669fa89d5867f1c3",
    "authorization": "authz-008"
  },
  "required_invariants": ["iliad-pre-review-before-implementation", "iliad-post-review-required", "iliad-products-enrollment-deferred"],
  "required_non_claims": ["no-autonomous-iliad-orchestrator", "iliad-enrollment-is-not-absorption"],
  "queries": [
    {
      "id": "orchestrator-exists",
      "query": "Does an autonomous Iliad orchestrator service exist?",
      "answer_kind": "boolean",
      "expected": false,
      "authority_anchor": { "non_claim": "no-autonomous-iliad-orchestrator" }
    },
    {
      "id": "lifecycle-phases",
      "query": "What are the three lifecycle phases, in order?",
      "answer_kind": "set",
      "expected": ["pre-review", "implementation", "post-review"],
      "authority_anchor": { "contract": "docs/institutional-memory/iliad/CONTRACTS/implementation-lifecycle.json" }
    },
    {
      "id": "pre-review-timing",
      "query": "When is the model + capability review recorded? (enum: before-implementation | during | after)",
      "answer_kind": "enum",
      "expected": "before-implementation",
      "authority_anchor": { "invariant": "iliad-pre-review-before-implementation" }
    },
    {
      "id": "delivered-without-retrospective",
      "query": "Can an enrollment be 'delivered' without a retrospective?",
      "answer_kind": "boolean",
      "expected": false,
      "authority_anchor": { "invariant": "iliad-post-review-required", "oracle": "docs/institutional-memory/verify-contracts.mjs" }
    },
    {
      "id": "optimization-destination",
      "query": "Where does a retrospective optimization take effect? (enum: next-run-pre-review-or-reviewed-change | automatically | it-does-not)",
      "answer_kind": "enum",
      "expected": "next-run-pre-review-or-reviewed-change",
      "authority_anchor": { "non_claim": "iliad-retrospective-optimizations-are-advisory" }
    },
    {
      "id": "deferred-products",
      "query": "Which products remain deferred for conscious Iliad enrollment?",
      "answer_kind": "set",
      "expected": ["ai-forge", "forge", "saas-forge"],
      "authority_anchor": { "decision": "AM-40", "contract": "docs/institutional-memory/iliad/CONTRACTS/enrollment.json" }
    },
    {
      "id": "enrollment-changes-governance",
      "query": "Does enrollment absorb a sub-system into the TELOS spine or change its governance?",
      "answer_kind": "boolean",
      "expected": false,
      "authority_anchor": { "non_claim": "iliad-enrollment-is-not-absorption" }
    },
    {
      "id": "model-actuality-proof",
      "query": "What proves which model ACTUALLY answered in a run? (enum: per-seat-provenance | the-pre-review | the-env-file)",
      "answer_kind": "enum",
      "expected": "per-seat-provenance",
      "authority_anchor": { "non_claim": "iliad-pre-review-does-not-verify-model-catalogs" }
    },
    {
      "id": "seat-change-mechanism",
      "query": "How does a newly-available model take a seat? (enum: reviewed-edit-to-seats-json | orchestration-script-change | automatic-upgrade)",
      "answer_kind": "enum",
      "expected": "reviewed-edit-to-seats-json",
      "authority_anchor": { "contract": "docs/institutional-memory/loadout/CONTRACTS/seat-prompt-separation.json", "template": "PRE-REVIEWS/TEMPLATE.json#model_review" }
    },
    {
      "id": "unregistered-implementation-detection",
      "query": "Can the verifier mechanically detect an implementation that never registered?",
      "answer_kind": "boolean",
      "expected": false,
      "authority_anchor": { "non_claim": "iliad-cannot-detect-unregistered-implementations" }
    }
  ]
}
