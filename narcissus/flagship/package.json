{
  "name": "narcissus-flagship",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Narcissus flagship — the TELOS development-story front-end ('Loom on Trial'). WebGL is paint; XState is truth.",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4317",
    "test": "npm run test:unit",
    "test:unit": "node --test scripts/test-verify-evidence.mjs",
    "test:e2e": "playwright test",
    "verify:evidence": "node scripts/verify-evidence.mjs",
    "verify:coverage": "node scripts/verify-coverage.mjs",
    "build:live-graph": "node scripts/build-live-graph.mjs",
    "prebuild": "node scripts/build-live-graph.mjs"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "@xstate/react": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "xstate": "^5.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.6.3",
    "vite": "^8.1.5"
  }
}
